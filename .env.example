# ICM GenAI Platform — Environment Variables
# Zkopíruj do .env a vyplň hodnoty

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Databricks Silver tabulky (vyplň až budou dostupné) ──────────────────────
DATABRICKS_HOST=https://adb-xxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi-xxxxx
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxx
DATABRICKS_SCHEMA_SILVER=icm_silver   # ověř přesný název v Databricks

# ── Přepnutí demo ↔ production ────────────────────────────────────────────────
# demo      → mock data ze Silver tabulek (výchozí, bez Databricks)
# production → reálné Databricks dotazy
ICM_ENV=demo
