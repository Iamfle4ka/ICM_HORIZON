# ICM GenAI Platform — Environment Variables
# Zkopíruj do .env a vyplň hodnoty

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Volba LLM providera: "anthropic" (výchozí) nebo "openai"
LLM_PROVIDER=anthropic

# Override modelu (volitelné — výchozí: claude-opus-4-6 / gpt-4o)
# LLM_MODEL=claude-opus-4-6

# ── Claude API (Anthropic) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── OpenAI API (alternativní provider) ───────────────────────────────────────
# Vyplň pouze pokud LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxx

# ── Databricks Silver tabulky ─────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi-xxxxx
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxx
DATABRICKS_CATALOG=vse_banka
DATABRICKS_SCHEMA_SILVER=obsluha_klienta
DATABRICKS_CATALOG_CRIBIS=vse_banka
DATABRICKS_SCHEMA_CRIBIS=investment_banking
DATABRICKS_SCHEMA_ESG=icm_gen_ai

# ── Přepnutí demo ↔ production ────────────────────────────────────────────────
# demo      → mock data (výchozí, bez Databricks, bez API klíče)
# production → reálné Databricks dotazy + AI uzly aktivní
ICM_ENV=demo
